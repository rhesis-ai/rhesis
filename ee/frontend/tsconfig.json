{
  "extends": "../../apps/frontend/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../../apps/frontend/src/*"],
      "react": ["../../apps/frontend/node_modules/@types/react"],
      "react/*": ["../../apps/frontend/node_modules/@types/react/*"],
      "@mui/material": ["../../apps/frontend/node_modules/@mui/material"],
      "@mui/material/*": ["../../apps/frontend/node_modules/@mui/material/*"],
      "@mui/icons-material": ["../../apps/frontend/node_modules/@mui/icons-material"],
      "@mui/icons-material/*": ["../../apps/frontend/node_modules/@mui/icons-material/*"],
      "next-auth": ["../../apps/frontend/node_modules/next-auth"],
      "next-auth/*": ["../../apps/frontend/node_modules/next-auth/*"],
      "@testing-library/react": ["../../apps/frontend/node_modules/@testing-library/react"],
      "@testing-library/user-event": ["../../apps/frontend/node_modules/@testing-library/user-event"],
      "@testing-library/jest-dom": ["../../apps/frontend/node_modules/@testing-library/jest-dom"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../apps/frontend/next-env.d.ts",
    "../../apps/frontend/src/types/*.d.ts",
    "../../apps/frontend/types/*.d.ts"
  ]
}
