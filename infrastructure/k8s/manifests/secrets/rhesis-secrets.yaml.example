apiVersion: v1
kind: Secret
metadata:
  name: rhesis-secrets
  namespace: rhesis
type: Opaque
data:
  #####################################################################################
  # 🔐 RHESIS KUBERNETES SECRETS CONFIGURATION
  #####################################################################################
  # Every value below is valid base64 out of the box, so this file applies as-is with
  # `kubectl apply` — a Kubernetes Secret's `data:` map must decode cleanly for every
  # key, so unlike a .env file there is no "just leave it blank" placeholder text.
  #
  # 1. REQUIRED, no safe default — ships blank; the app won't start without these.
  #    Run ../generate-secrets.sh to fill them in (base64-encoded, no manual steps).
  # 2. Local defaults — already set to the same values docker-compose.yml uses for
  #    local development. Change only for production.
  # 3. Optional — ships blank (feature disabled) or with a harmless placeholder,
  #    matching docker-compose.yml. Set your own with:
  #    ../generate-secrets.sh encode "your-actual-value"
  #####################################################################################

  # =============================================================================
  # 🔧 REQUIRED — no safe default, run ../generate-secrets.sh to fill these in
  # =============================================================================
  JWT_SECRET_KEY: ""
  NEXTAUTH_SECRET: ""
  # Generate: openssl rand -hex 32
  SESSION_SECRET_KEY: ""
  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  DB_ENCRYPTION_KEY: ""

  # =============================================================================
  # 🗄️ DATABASE — local default matches docker-compose.yml's postgres service
  # =============================================================================
  APP_DB_PASS: cmhlc2lzLXBhc3N3b3Jk  # rhesis-password (base64) — change for production
  # Migration / admin password (optional — leave empty to fall back to APP_DB_PASS)
  # ADMIN_DB_PASS: <BASE64_ENCODED_ADMIN_DATABASE_PASSWORD>

  # =============================================================================
  # 🔴 REDIS — local default matches docker-compose.yml's redis service
  # =============================================================================
  REDIS_PASSWORD: cmhlc2lzLXJlZGlzLXBhc3M=  # rhesis-redis-pass (base64) — change for production

  # =============================================================================
  # 🤖 AI MODELS
  # =============================================================================
  # Rhesis-hosted models (get one at https://app.rhesis.ai/tokens). Placeholder below
  # matches docker-compose.yml — generation/evaluation calls fail until you set a real key.
  RHESIS_API_KEY: eW91ci1yaGVzaXMtYXBpLWtleQ==  # your-rhesis-api-key (base64)

  # Alternative providers (optional — leave blank unless you use them)
  AZURE_OPENAI_API_KEY: ""
  OPENAI_API_KEY: ""
  GEMINI_API_KEY: ""
  GOOGLE_API_KEY: ""

  # =============================================================================
  # 🌐 GOOGLE OAUTH (optional — leave blank to disable Google sign-in)
  # =============================================================================
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""

  # =============================================================================
  # 📧 EMAIL (optional — placeholders match docker-compose.yml, notifications
  # silently no-op until you set real SMTP credentials)
  # =============================================================================
  SMTP_HOST: c210cC5leGFtcGxlLmNvbQ==  # smtp.example.com (base64)
  SMTP_USER: dXNlckBleGFtcGxlLmNvbQ==  # user@example.com (base64)
  SMTP_PASSWORD: eW91ci1zbXRwLXBhc3N3b3Jk  # your-smtp-password (base64)
  FROM_EMAIL: bm9yZXBseUBleGFtcGxlLmNvbQ==  # noreply@example.com (base64)

  # =============================================================================
  # 🔗 EXTERNAL SERVICES (optional)
  # =============================================================================
  WORKER_API_URL: ""

  # Shared secret between the backend and the bundled chatbot demo endpoint.
  # Optional: without it, the chatbot demo still works but falls back to public rate limits.
  CHATBOT_API_KEY: ""

  # =============================================================================
  # 🗂️ OBJECT STORAGE — local default matches docker-compose.yml (bind-mounted
  # filesystem storage). Set STORAGE_SERVICE_URI to a gs:// or s3:// bucket URI
  # for cloud storage instead.
  # =============================================================================
  STORAGE_SERVICE_URI: ZmlsZTovLy9hcHAvc3RvcmFnZQ==  # file:///app/storage (base64)
  # Service-account JSON key (base64-encoded) for GCS presigned-URL signing.
  # Required only when STORAGE_SERVICE_URI is a gs:// bucket.
  STORAGE_SERVICE_ACCOUNT_KEY: ""
  LOCAL_STORAGE_PATH: L3RtcC9yaGVzaXMtZmlsZXM=  # /tmp/rhesis-files (base64)

  # =============================================================================
  # 🏢 ENTERPRISE FEATURES (optional — ships blank, feature disabled until set)
  # =============================================================================
  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  SSO_ENCRYPTION_KEY: ""
  AUDIT_HASH_KEY: ""

  #####################################################################################
  # 📚 QUICK START GUIDE
  #####################################################################################
  # 1. Run ../generate-secrets.sh — copies this file to rhesis-secrets.yaml (if missing)
  #    and fills JWT_SECRET_KEY, NEXTAUTH_SECRET, SESSION_SECRET_KEY, DB_ENCRYPTION_KEY.
  # 2. Everything else already has a working local default or ships blank (disabled).
  #    To set one, encode it and paste the result over the matching key:
  #    ../generate-secrets.sh encode "your-actual-value"
  # 3. Change APP_DB_PASS and REDIS_PASSWORD to strong, unique values for production.
  # 4. Apply the secret: kubectl apply -f rhesis-secrets.yaml -n rhesis
  #
  # 🔒 SECURITY NOTES:
  # - Never commit the actual rhesis-secrets.yaml file to version control!
  #   (already gitignored — see infrastructure/k8s/manifests/secrets/*)
  # - Use strong, unique passwords for production
  # - Rotate secrets regularly
  #####################################################################################
