# Example Terraform variables configuration
# Copy this file to terraform.tfvars and customize the values

project_id = "example-project-id"
region     = "gcp-region"

# Which environments to deploy. Default: all three.
# For dev-only:  enabled_environments = ["dev"]
# For dev + stg: enabled_environments = ["dev", "stg"]
enabled_environments = ["dev", "stg", "prd"]

# Deletion protection (single place for root apply)
# WireGuard server
wireguard_deletion_protection = true
# GKE clusters (dev/stg typically false, prd true)
gke_deletion_protection = {
  dev = false
  stg = false
  prd = true
}

# GCS: file storage for all envs; CNPG backup buckets for stg/prd only (defaults in variables.tf).
# When stg/prd are enabled and cnpg_backup_bucket_name is non-empty, modules
# cnpg_barman_stg / cnpg_barman_prd create a Barman GSA, bucket IAM (objectUser +
# bucketViewer for storage.buckets.get),
# and GSM secrets stg-rhesis-cnpg-gcs-sa-key / prd-rhesis-cnpg-gcs-sa-key (see
# kubernetes/clusters/<env>/rhesis/cnpg-gcs-externalsecret.yaml).
# Override so bucket names match STORAGE_SERVICE_URI and CNPG backup.
# gcs = {
#   dev = { file_storage_bucket_name = "sources-file-storage-example" }
#   stg = {
#     file_storage_bucket_name  = "sources-file-storage-example"
#     cnpg_backup_bucket_name  = "cnpg-backup-storage-example"
#   }
#   prd = {
#     file_storage_bucket_name  = "sources-file-storage-example"
#     cnpg_backup_bucket_name  = "cnpg-backup-storage-example"
#   }
# }

# WireGuard VPN peers configuration
# Each peer gets a unique IP within the WireGuard network (10.0.0.0/24)
# and access to specific environment subnets
wireguard_peers = [
  {
    identifier = "admin-alice"
    ip         = "10.0.0.2"
    subnets    = ["dev", "stg", "prd"] # Full access
  },
  {
    identifier = "dev-bob"
    ip         = "10.0.0.3"
    subnets    = ["dev", "stg"] # Dev and staging only
  },
  {
    identifier = "dev-charlie"
    ip         = "10.0.0.4"
    subnets    = ["dev"] # Dev only
  }
]

# SSH access: OS Login + IAP tunneling is enabled by default.
# Connect with: gcloud compute ssh wireguard-server --tunnel-through-iap --zone=ZONE
# Grant access via: gcloud projects add-iam-policy-binding PROJECT --member=user:EMAIL --role=roles/iap.tunnelResourceAccessor
