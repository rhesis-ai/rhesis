# Required: Gemini API key (also accepts GEMINI_API_KEY)
GOOGLE_API_KEY=

# Optional: Gemini model id (default: gemini-3.1-flash-lite)
DR_RHESIS_MODEL=gemini-3.1-flash-lite

# Optional: Rhesis tracing (set both to ship traces to the Rhesis backend)
RHESIS_API_KEY=
RHESIS_PROJECT_ID=

# Optional: Rhesis backend + frontend URLs for local development.
# RHESIS_BASE_URL is where spans are shipped; RHESIS_FRONTEND_URL builds the
# clickable trace_url deep link returned from a chat turn.
RHESIS_BASE_URL=http://localhost:8080
RHESIS_FRONTEND_URL=http://localhost:3000

# Required by the Haystack RhesisConnector to capture span input/output content.
# The app sets this automatically, but keep it here for the terminal chat.
HAYSTACK_CONTENT_TRACING_ENABLED=true
