# Rhesis SDK Configuration
# Copy this file to .env and fill in your values
# Or export these variables in your shell

# Required: Rhesis API credentials
RHESIS_API_KEY=your-rhesis-api-key-here
RHESIS_PROJECT_ID=your-project-id-here
RHESIS_ENVIRONMENT=development

# Optional: Override backend URL (defaults to http://localhost:8080)
# RHESIS_BASE_URL=http://localhost:8080

# --- LLM provider keys (use the key that matches your example) ---

# Google Gemini (langchain_example.py)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# OpenAI (openai_sdk_example.py — default provider)
# OPENAI_API_KEY=sk-...

# Anthropic (openai_sdk_example.py — set OPENAI_SDK_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Direct SDK example only
# OPENAI_SDK_PROVIDER=openai
# OPENAI_SDK_MODEL=gpt-4o-mini
# OPENAI_SDK_PROVIDER=anthropic
# ANTHROPIC_SDK_MODEL=claude-3-5-haiku-20241022

