# Rhesis SDK Configuration
# Copy this file to .env and fill in your values
# Or export these variables in your shell

# Required: Rhesis API credentials
RHESIS_API_KEY=your-rhesis-api-key-here
RHESIS_PROJECT_ID=your-project-id-here
RHESIS_ENVIRONMENT=development

# Optional: Override backend URL (defaults to http://localhost:8080)
# RHESIS_BASE_URL=http://localhost:8080

# --- LLM keys (pick one; used by langchain / llamaindex examples) ---

# Google Gemini
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# OpenAI (llamaindex_example.py with LLAMAINDEX_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# LlamaIndex only
# LLAMAINDEX_PROVIDER=openai
# LLAMAINDEX_MODEL=gpt-4o-mini
# LLAMAINDEX_EMBED_MODEL=text-embedding-3-small
# LLAMAINDEX_PROVIDER=gemini
# LLAMAINDEX_MODEL=gemini-2.0-flash
# LLAMAINDEX_EMBED_MODEL=text-embedding-004

