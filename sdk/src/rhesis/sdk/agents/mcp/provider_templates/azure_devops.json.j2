{
  "mcpServers": {
    "azure_devops": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@tiberriver256/mcp-server-azure-devops"],
      "env": {
        "AZURE_DEVOPS_ORG_URL": {{ AZURE_DEVOPS_ORG_URL | tojson }},
        "AZURE_DEVOPS_AUTH_METHOD": "pat",
        "AZURE_DEVOPS_PAT": {{ AZURE_DEVOPS_PAT | tojson }}
      }
    }
  }
}
