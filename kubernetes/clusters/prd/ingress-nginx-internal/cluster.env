# Values for internal ingress LB. Must match Terraform:
#   - region → var.region (terraform.tfvars)
#   - ilb-subnet-name → subnet-ilb-<env>-<region> (see modules/network/gcp/subnets.tf)
# When changing region, update Terraform and this file.
region=europe-west4
ilb-subnet-name=subnet-ilb-prd-europe-west4
internal-lb-ip=10.6.2.10
