{
  "name": "rhesis-app",
  "version": "0.10.0",
  "scripts": {
    "dev": "next dev --webpack -H 0.0.0.0 -p 3000",
    "dev:turbo": "next dev --turbo -H 0.0.0.0 -p 3000",
    "build": "npm run clean && next build --webpack",
    "postinstall": "patch-package",
    "start": "next start -p ${PORT}",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx && npm --prefix ../../ee/frontend run lint",
    "lint:errors": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0 && npm --prefix ../../ee/frontend run lint",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix && npm --prefix ../../ee/frontend run lint:fix",
    "check:ee-boundary": "node scripts/check-ee-boundary.mjs",
    "format": "prettier --write . && npm --prefix ../../ee/frontend run format",
    "format:check": "prettier --check . && npm --prefix ../../ee/frontend run format:check",
    "type-check": "tsc --noEmit && tsc --noEmit -p ../../ee/frontend/tsconfig.json",
    "generate-templates": "node scripts/generate-templates.js",
    "prebuild": "npm run generate-templates",
    "clean": "rm -rf .next",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "version:check": "echo \"Current version: $(node -p \\\"require('./package.json').version\\\")\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --coverageReporters text json-summary lcov --watchAll=false",
    "test:clean-coverage": "rm -rf coverage/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7",
    "@mui/material": "^7",
    "@mui/material-nextjs": "^7",
    "@mui/x-charts": "^8.19.0",
    "@mui/x-data-grid": "^7.27.3",
    "@mui/x-date-pickers": "^7.28.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.207.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@rhesis/ee-frontend": "file:../../ee/frontend",
    "@tanstack/react-query": "^5.100.10",
    "@types/dagre": "^0.7.53",
    "@types/nodemailer": "^6.4.17",
    "@types/prismjs": "^1.26.5",
    "@types/react-mentions": "^4.4.1",
    "@uwdata/mosaic-core": "^0.26.0",
    "@uwdata/mosaic-spec": "^0.26.0",
    "@uwdata/mosaic-sql": "^0.26.0",
    "@uwdata/vgplot": "^0.26.0",
    "critters": "^0.0.23",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "driver.js": "^1.3.6",
    "embedding-atlas": "^0.20.0",
    "emoji-picker-react": "^4.13.3",
    "invariant": "^2.2.4",
    "lucide-react": "^0.475.0",
    "markdown-to-jsx": "^9.7.1",
    "mui-markdown": "^2.1.0",
    "next": "^16.2.3",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^9.0.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-mentions": "^4.4.10",
    "reactflow": "^11.11.4",
    "recharts": "^2.15.0"
  },
  "overrides": {
    "glob": "^10.0.0",
    "rimraf": "^5.0.0",
    "inflight": "npm:@humanfs/core@^1.0.0",
    "@babel/traverse": ">=7.23.2",
    "fast-xml-parser": ">=5.7.0",
    "loader-utils": ">=2.0.3",
    "webpack": ">=5.76.0",
    "minimatch": ">=10.2.3",
    "@isaacs/brace-expansion": ">=5.0.1",
    "brace-expansion": ">=5.0.6",
    "braces": ">=3.0.3",
