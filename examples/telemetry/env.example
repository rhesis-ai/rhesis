# Rhesis SDK Configuration
# Copy this file to .env and fill in your values
# Or export these variables in your shell

# Required: Rhesis API credentials
RHESIS_API_KEY=your-rhesis-api-key-here
RHESIS_PROJECT_ID=your-project-id-here
RHESIS_ENVIRONMENT=development

# Optional: Override backend URL (defaults to http://localhost:8080)
# RHESIS_BASE_URL=http://localhost:8080

# --- LLM provider (pick one; used by langchain / pydantic_ai examples) ---

# Google Gemini
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# OpenAI (use with PYDANTIC_AI_MODEL=openai:gpt-4o-mini in pydantic_ai_example.py)
# OPENAI_API_KEY=sk-...

# Pydantic AI only: override model id. Default: openai:gpt-4o-mini
# PYDANTIC_AI_MODEL=openai:gpt-4o-mini
# PYDANTIC_AI_MODEL=google-gla:gemini-2.0-flash

